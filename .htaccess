# Tradie Sites Co. — Public Site .htaccess
# VentraIP / Apache

# Set Groq API key (replace with real key)
# SetEnv GROQ_API_KEY your_key_here  (set on server, not in git)

# Set ZeptoMail API token for transactional email delivery.
# Generate the send-mail token at https://www.zoho.com/zeptomail/ (AU region) with
# info@tradiebud.tech configured as a verified sender + SPF/DKIM on tradiebud.tech.
# Without this the code falls back to PHP mail() which hits spam folders on shared hosting.
# SetEnv ZEPTO_TOKEN your_zeptomail_send_token_here  (set on server, not in git)

# Set admin email
SetEnv ADMIN_EMAIL info@tradiebud.tech

# Security headers
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-XSS-Protection "1; mode=block"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# Deny access to CSV files
<Files "leads.csv">
    Order Allow,Deny
    Deny from all
</Files>

# Deny access to .htaccess itself
<Files ".htaccess">
    Order Allow,Deny
    Deny from all
</Files>

# Enable URL rewriting
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Force HTTPS
    RewriteCond %{HTTPS} off
    RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # Remove www
    RewriteCond %{HTTP_HOST} ^www\.(.*)$ [NC]
    RewriteRule ^(.*)$ https://%1/$1 [R=301,L]

    # Pretty URLs for trade pages: /trades/plumber -> /trades/template.php?slug=plumber
    # /trades/ is handled by DirectoryIndex -> /trades/index.php
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^trades/([a-z][a-z0-9-]*)/?$ /trades/template.php?slug=$1 [L,QSA]

    # Pretty URLs for blog posts: /blog/some-slug -> /blog/template.php?slug=some-slug
    # /blog/ is handled by DirectoryIndex -> /blog/index.php
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^blog/([a-z0-9][a-z0-9-]*)/?$ /blog/template.php?slug=$1 [L,QSA]

    # Dynamic sitemap: /sitemap.xml -> /sitemap.php
    RewriteRule ^sitemap\.xml$ /sitemap.php [L]

    # Pretty URL: /signup/pay -> /signup/pay.php (preserve query string for ?ref=)
    RewriteRule ^signup/pay/?$ /signup/pay.php [L,QSA]

    # Legal pretty URLs
    RewriteRule ^privacy/?$ /privacy.php [L]
    RewriteRule ^terms/?$   /terms.php   [L]
</IfModule>

# Custom 404 — served by /404.php (renders with Bold Tradie Energy chrome and an HTTP 404 status)
ErrorDocument 404 /404.php

# Block direct access to the entire /signups/ data folder (uploads, CSV, JSON records)
RedirectMatch 403 ^/signups(/.*)?$

# Block direct access to trade data + partial includes
<FilesMatch "^_">
    Require all denied
</FilesMatch>

# Compress output
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript application/json
</IfModule>

# Cache static assets
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType image/jpeg "access plus 1 month"
    ExpiresByType image/png "access plus 1 month"
    ExpiresByType image/svg+xml "access plus 1 month"
</IfModule>
